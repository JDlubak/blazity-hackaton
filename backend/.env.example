# Copy to backend/.env and fill in. backend/.env is gitignored — never commit it.

# Required for B2's live analysis (Phase 2). Not needed while USE_STUB=1.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown).
# HOST=127.0.0.1
# PORT=5000
# FLASK_DEBUG=1
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# MAX_DRAFT_CHARS=10000

# Phase 1 stub mode (returns the frozen contract example). Set to 0 in Phase 2
# once backend/analysis/ exists.
USE_STUB=1
