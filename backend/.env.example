# Copy to backend/.env and fill in. backend/.env is gitignored — never commit it.

# Required for B2's live analysis (used by default once backend/analysis/ exists).
# Only optional if you force stub mode with USE_STUB=1.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown).
# HOST=127.0.0.1
# PORT=5000
# FLASK_DEBUG=1
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# MAX_DRAFT_CHARS=10000

# Analysis mode. Leave UNSET to auto-detect: live when backend/analysis/ exists,
# stub otherwise. Force with USE_STUB=1 (always stub, no API key needed) or
# USE_STUB=0 (always call B2).
# USE_STUB=1
